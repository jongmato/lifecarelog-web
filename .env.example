# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://lifecarelog.co.kr
NEXT_PUBLIC_APP_ENV=development

# ─── Resend (Email) ─────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# ─── Cloudflare Turnstile ────────────────────────────────────────────────────
# Get from: https://developers.cloudflare.com/turnstile/get-started/
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Google Analytics 4 ─────────────────────────────────────────────────────
# Get from: https://analytics.google.com/ > Admin > Data Streams > Measurement ID
NEXT_PUBLIC_GA_ID=

# ─── Sentry ─────────────────────────────────────────────────────────────────
# Get from: https://sentry.io > Settings > Projects > lifecarelog-web > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Get from: https://sentry.io > Settings > Auth Tokens (for source map upload)
SENTRY_AUTH_TOKEN=

# ─── Cloudflare (for deploy) ────────────────────────────────────────────────
# Set in GitHub Actions secrets, not here
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
